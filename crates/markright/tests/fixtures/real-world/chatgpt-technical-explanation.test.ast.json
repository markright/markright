{
  "children": [
    {
      "content": [
        {
          "type": "text",
          "value": "How HTTPS Works"
        }
      ],
      "level": 1,
      "type": "heading"
    },
    {
      "content": [
        {
          "children": [
            {
              "type": "text",
              "value": "HTTPS"
            }
          ],
          "type": "bold"
        },
        {
          "type": "text",
          "value": " (Hypertext Transfer Protocol Secure) is the secure version of HTTP. It uses "
        },
        {
          "children": [
            {
              "type": "text",
              "value": "TLS"
            }
          ],
          "type": "italic"
        },
        {
          "type": "text",
          "value": " (Transport Layer Security) to encrypt communication between a client and a server."
        }
      ],
      "type": "paragraph"
    },
    {
      "content": [
        {
          "type": "text",
          "value": "The TLS Handshake"
        }
      ],
      "level": 2,
      "type": "heading"
    },
    {
      "content": [
        {
          "type": "text",
          "value": "The TLS handshake establishes a secure connection in several steps:"
        }
      ],
      "type": "paragraph"
    },
    {
      "items": [
        {
          "children": [
            {
              "content": [
                {
                  "children": [
                    {
                      "type": "text",
                      "value": "Client Hello"
                    }
                  ],
                  "type": "bold"
                },
                {
                  "type": "text",
                  "value": ": The client sends supported cipher suites and a random number"
                }
              ],
              "type": "paragraph"
            }
          ]
        },
        {
          "children": [
            {
              "content": [
                {
                  "children": [
                    {
                      "type": "text",
                      "value": "Server Hello"
                    }
                  ],
                  "type": "bold"
                },
                {
                  "type": "text",
                  "value": ": The server selects a cipher suite and sends its certificate"
                }
              ],
              "type": "paragraph"
            }
          ]
        },
        {
          "children": [
            {
              "content": [
                {
                  "children": [
                    {
                      "type": "text",
                      "value": "Key Exchange"
                    }
                  ],
                  "type": "bold"
                },
                {
                  "type": "text",
                  "value": ": Both parties agree on a shared secret using "
                },
                {
                  "type": "inline_code",
                  "value": "Diffie-Hellman"
                },
                {
                  "type": "text",
                  "value": " or similar"
                }
              ],
              "type": "paragraph"
            }
          ]
        },
        {
          "children": [
            {
              "content": [
                {
                  "children": [
                    {
                      "type": "text",
                      "value": "Finished"
                    }
                  ],
                  "type": "bold"
                },
                {
                  "type": "text",
                  "value": ": Both sides verify the handshake and begin encrypted communication"
                }
              ],
              "type": "paragraph"
            }
          ]
        }
      ],
      "start": 1,
      "type": "ordered_list"
    },
    {
      "content": [
        {
          "type": "text",
          "value": "Certificate Chain"
        }
      ],
      "level": 2,
      "type": "heading"
    },
    {
      "body": "Root CA (trusted by browser)\n  └── Intermediate CA\n        └── Server Certificate (your-domain.com)",
      "type": "code_block"
    },
    {
      "content": [
        {
          "type": "text",
          "value": "The browser validates the chain by checking:"
        }
      ],
      "type": "paragraph"
    },
    {
      "items": [
        {
          "children": [
            {
              "content": [
                {
                  "type": "text",
                  "value": "The certificate is not expired"
                }
              ],
              "type": "paragraph"
            }
          ]
        },
        {
          "children": [
            {
              "content": [
                {
                  "type": "text",
                  "value": "The issuer signature is valid"
                }
              ],
              "type": "paragraph"
            }
          ]
        },
        {
          "children": [
            {
              "content": [
                {
                  "type": "text",
                  "value": "The root CA is in the browser's trust store"
                }
              ],
              "type": "paragraph"
            }
          ]
        }
      ],
      "type": "unordered_list"
    },
    {
      "content": [
        {
          "type": "text",
          "value": "Cipher Suite Example"
        }
      ],
      "level": 2,
      "type": "heading"
    },
    {
      "content": [
        {
          "type": "text",
          "value": "A typical cipher suite looks like "
        },
        {
          "type": "inline_code",
          "value": "TLS_AES_256_GCM_SHA384"
        },
        {
          "type": "text",
          "value": ":"
        }
      ],
      "type": "paragraph"
    },
    {
      "items": [
        {
          "definitions": [
            [
              {
                "type": "text",
                "value": "The protocol version"
              }
            ]
          ],
          "term": [
            {
              "type": "text",
              "value": "TLS"
            }
          ]
        },
        {
          "definitions": [
            [
              {
                "type": "text",
                "value": "The symmetric encryption algorithm"
              }
            ],
            [
              {
                "type": "text",
                "value": "AES with 256-bit key in Galois/Counter Mode"
              }
            ]
          ],
          "term": [
            {
              "type": "text",
              "value": "AES_256_GCM"
            }
          ]
        },
        {
          "definitions": [
            [
              {
                "type": "text",
                "value": "The hash function used for message authentication"
              }
            ]
          ],
          "term": [
            {
              "type": "text",
              "value": "SHA384"
            }
          ]
        }
      ],
      "type": "definition_list"
    },
    {
      "content": [
        {
          "type": "text",
          "value": "Common Mistakes"
        }
      ],
      "level": 2,
      "type": "heading"
    },
    {
      "children": [
        {
          "content": [
            {
              "type": "text",
              "value": "Never disable certificate verification in production code, even for testing."
            }
          ],
          "type": "paragraph"
        }
      ],
      "foldable": false,
      "kind": "warning",
      "type": "admonition"
    },
    {
      "children": [
        {
          "content": [
            {
              "type": "text",
              "value": "Expired certificates cause outright connection failures. Mixed HTTP and HTTPS content will be blocked by modern browsers."
            }
          ],
          "type": "paragraph"
        }
      ],
      "foldable": false,
      "kind": "caution",
      "type": "admonition"
    },
    {
      "content": [
        {
          "type": "text",
          "value": "Useful Commands"
        }
      ],
      "level": 2,
      "type": "heading"
    },
    {
      "body": "# Check certificate of a domain\nopenssl s_client -connect example.com:443 -servername example.com\n\n# Generate a self-signed certificate\nopenssl req -x509 -newkey rsa:4096 -keyout key.pem -out cert.pem -days 365",
      "lang": "bash",
      "type": "code_block"
    },
    {
      "content": [
        {
          "type": "text",
          "value": "For more information, see "
        },
        {
          "children": [
            {
              "type": "text",
              "value": "Mozilla's TLS Guide"
            }
          ],
          "type": "link",
          "url": "https://wiki.mozilla.org/Security/Server_Side_TLS"
        },
        {
          "type": "text",
          "value": "."
        }
      ],
      "type": "paragraph"
    }
  ]
}