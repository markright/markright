      "content": [
        {
          "type": "text",
          "value": "Release Notes: v3.0.0"
        }
      ],
      "level": 1,
      "type": "heading"
    },
    {
      "content": [
        {
          "type": "text",
          "value": "We are excited to announce version 3.0 of the platform. This is a major release with new features, performance improvements, and breaking changes."
        }
      ],
      "type": "paragraph"
    },
    {
      "children": [
        {
          "content": [
            {
              "type": "text",
              "value": "This release contains "
            },
            {
              "children": [
                {
                  "type": "text",
                  "value": "breaking changes"
                }
              ],
              "type": "bold"
            },
            {
              "type": "text",
              "value": ". Please read the migration guide carefully."
            }
          ],
          "type": "paragraph"
        }
      ],
      "foldable": false,
      "kind": "important",
      "type": "admonition"
    },
    {
      "content": [
        {
          "type": "text",
          "value": "New Features"
        }
      ],
      "level": 2,
      "type": "heading"
    },
    {
      "content": [
        {
          "type": "text",
          "value": "Real-Time Collaboration"
        }
      ],
      "level": 3,
      "type": "heading"
    },
    {
      "content": [
        {
          "type": "text",
          "value": "Multiple users can now edit documents simultaneously with live cursor tracking and conflict resolution."
        }
      ],
      "type": "paragraph"
    },
    {
      "content": [
        {
          "type": "text",
          "value": "Advanced Search"
        }
      ],
      "level": 3,
      "type": "heading"
    },
    {
      "content": [
        {
          "type": "text",
          "value": "Full-text search with support for:"
        }
      ],
      "type": "paragraph"
    },
    {
      "items": [
        {
          "children": [
            {
              "content": [
                {
                  "type": "text",
                  "value": "Boolean operators ("
                },
                {
                  "type": "inline_code",
                  "value": "AND"
                },
                {
                  "type": "text",
                  "value": ", "
                },
                {
                  "type": "inline_code",
                  "value": "OR"
                },
                {
                  "type": "text",
                  "value": ", "
                },
                {
                  "type": "inline_code",
                  "value": "NOT"
                },
                {
                  "type": "text",
                  "value": ")"
                }
              ],
              "type": "paragraph"
            }
          ]
        },
        {
          "children": [
            {
              "content": [
                {
                  "type": "text",
                  "value": "Phrase matching with "
                },
                {
                  "type": "inline_code",
                  "value": "\"exact phrase\""
                }
              ],
              "type": "paragraph"
            }
          ]
        },
        {
          "children": [
            {
              "content": [
                {
                  "type": "text",
                  "value": "Field-specific queries with "
                },
                {
                  "type": "inline_code",
                  "value": "field:value"
                }
              ],
              "type": "paragraph"
            }
          ]
        },
        {
          "children": [
            {
              "content": [
                {
                  "type": "text",
                  "value": "Wildcard patterns with "
                },
                {
                  "type": "inline_code",
                  "value": "*"
                }
              ],
              "type": "paragraph"
            }
          ]
        }
      ],
      "type": "unordered_list"
    },
    {
      "content": [
        {
          "type": "text",
          "value": "Export Improvements"
        }
