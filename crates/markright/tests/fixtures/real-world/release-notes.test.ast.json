      "rows": [
        [
          [
            {
              "type": "text",
              "value": "PDF"
            }
          ],
          [
            {
              "type": "text",
              "value": "High-fidelity PDF with embedded fonts"
            }
          ]
        ],
        [
          [
            {
              "type": "text",
              "value": "EPUB"
            }
          ],
          [
            {
              "type": "text",
              "value": "E-book format for mobile readers"
