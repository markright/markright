            }
          ],
          "type": "bold"
        },
        {
          "type": "text",
          "value": " (BST) is a data structure where each node has at most two children, and for every node, all values in the left subtree are "
        },
        {
          "children": [
            {
              "type": "text",
              "value": "smaller"
            }
          ],
          "type": "italic"
        },
        {
          "type": "text",
          "value": " and all values in the right subtree are "
        },
        {
          "children": [
