      "content": [
        {
          "type": "text",
          "value": "Overview"
        }
      ],
      "level": 2,
      "type": "heading"
    },
    {
      "content": [
        {
          "type": "text",
          "value": "Rust uses an "
        },
        {
          "children": [
            {
              "type": "text",
              "value": "ownership system"
            }
          ],
          "type": "bold"
        },
        {
          "type": "text",
          "value": " to manage memory without a garbage collector. Every value has a single "
        },
        {
          "children": [
            {
              "type": "text",
              "value": "owner"
            }
          ],
          "type": "italic"
        },
        {
          "type": "text",
          "value": ", and when the owner goes out of scope, the value is dropped."
        }
      ],
      "type": "paragraph"
    },
    {
      "content": [
        {
          "target": "ownership-diagram.png",
          "type": "wiki_embed"
        }
      ],
      "type": "paragraph"
    },
    {
      "content": [
        {
          "type": "text",
          "value": "Key Rules"
        }
      ],
      "level": 2,
      "type": "heading"
    },
    {
      "items": [
        {
          "children": [
            {
              "content": [
                {
                  "type": "text",
                  "value": "Each value has exactly one owner"
                }
              ],
              "type": "paragraph"
            }
          ]
        },
        {
          "children": [
            {
              "content": [
                {
                  "type": "text",
                  "value": "When the owner goes out of scope, the value is dropped"
                }
              ],
              "type": "paragraph"
            }
          ]
        },
        {
          "children": [
            {
              "content": [
                {
                  "type": "text",
                  "value": "Ownership can be transferred via "
                },
                {
                  "type": "inline_code",
                  "value": "move"
                }
              ],
              "type": "paragraph"
            }
          ]
        }
      ],
      "start": 1,
      "type": "ordered_list"
    },
    {
