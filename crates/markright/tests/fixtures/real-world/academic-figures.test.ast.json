      "content": [
        {
          "type": "text",
          "value": "Conclusion"
        }
      ],
      "level": 2,
      "type": "heading"
    },
    {
      "content": [
        {
          "type": "text",
          "value": "Weight-sharing NAS methods offer the best trade-off between search efficiency and final accuracy. We recommend DARTS as the default choice for architecture search on image classification tasks."
        }
      ],
      "type": "paragraph"
