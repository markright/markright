      "children": [
        {
          "content": [
            {
              "type": "text",
              "value": "The search cost of NASNet (48000 GPU hours) makes it impractical for most research labs."
            }
          ],
          "type": "paragraph"
        }
      ],
      "foldable": false,
      "kind": "note",
      "type": "admonition"
    },
    {
      "children": [
        {
          "content": [
            {
              "type": "text",
              "value": "Accuracy numbers should be interpreted carefully. Small differences (less than 0.3%) may not be statistically significant."
            }
          ],
          "type": "paragraph"
        }
      ],
      "foldable": false,
      "kind": "warning",
      "type": "admonition"
    },
