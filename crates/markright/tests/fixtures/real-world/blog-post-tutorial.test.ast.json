      "content": [
        {
          "type": "text",
          "value": "Getting Started with Docker"
        }
      ],
      "level": 1,
      "type": "heading"
    },
    {
      "content": [
        {
          "type": "text",
          "value": "Docker is a platform for building, shipping, and running applications in containers. This tutorial will walk you through the basics."
        }
      ],
      "type": "paragraph"
    },
    {
      "content": [
        {
          "type": "text",
          "value": "Prerequisites"
        }
      ],
      "level": 2,
      "type": "heading"
    },
    {
      "items": [
        {
          "children": [
            {
              "content": [
                {
                  "type": "text",
                  "value": "Install Docker Desktop"
                }
              ],
              "type": "paragraph"
            }
          ],
          "state": "open"
        },
        {
          "children": [
            {
              "content": [
                {
                  "type": "text",
                  "value": "Verify installation with "
                },
                {
                  "type": "inline_code",
                  "value": "docker --version"
                }
              ],
              "type": "paragraph"
            }
          ],
          "state": "open"
        },
        {
          "children": [
            {
              "content": [
                {
                  "type": "text",
                  "value": "Create a Docker Hub account"
                }
              ],
              "type": "paragraph"
            }
          ],
          "state": "open"
        }
      ],
      "type": "task_list"
    },
    {
      "content": [
        {
          "type": "text",
          "value": "Your First Container"
        }
      ],
      "level": 2,
      "type": "heading"
    },
    {
      "body": "docker run hello-world",
      "lang": "bash",
      "type": "code_block"
    },
    {
      "content": [
        {
          "type": "text",
          "value": "This pulls the "
        },
        {
          "type": "inline_code",
          "value": "hello-world"
        },
        {
          "type": "text",
          "value": " image and runs it in a container. You should see a confirmation message."
        }
      ],
      "type": "paragraph"
    },
    {
      "content": [
        {
          "type": "text",
          "value": "Writing a Dockerfile"
        }
      ],
      "level": 2,
      "type": "heading"
    },
    {
      "content": [
        {
          "type": "text",
          "value": "Create a file named "
        },
        {
          "type": "inline_code",
          "value": "Dockerfile"
        },
        {
          "type": "text",
          "value": " in your project:"
        }
      ],
      "type": "paragraph"
    },
    {
      "body": "FROM node:20-alpine\nWORKDIR /app\nCOPY package*.json ./\nRUN npm install\nCOPY . .\nEXPOSE 3000\nCMD [\"node\", \"server.js\"]",
      "lang": "dockerfile",
      "type": "code_block"
    },
    {
      "content": [
        {
          "type": "text",
          "value": "Building and Running"
        }
      ],
      "level": 2,
      "type": "heading"
    },
    {
      "body": "# Build the image\ndocker build -t my-app .\n\n# Run the container\ndocker run -p 3000:3000 my-app",
      "lang": "bash",
      "type": "code_block"
    },
    {
      "content": [
        {
          "type": "text",
          "value": "Docker Compose"
        }
      ],
      "level": 2,
      "type": "heading"
    },
    {
      "content": [
        {
          "type": "text",
          "value": "For multi-container applications, use Docker Compose:"
        }
      ],
      "type": "paragraph"
    },
    {
      "body": "services:\n  web:\n    build: .\n    ports:\n      - \"3000:3000\"\n  db:\n    image: postgres:16\n    environment:\n      POSTGRES_PASSWORD: secret",
      "lang": "yaml",
      "type": "code_block"
    },
    {
      "content": [
        {
          "type": "text",
          "value": "Then run:"
        }
      ],
      "type": "paragraph"
    },
    {
      "body": "docker compose up",
      "lang": "bash",
      "type": "code_block"
    },
    {
      "content": [
        {
          "type": "text",
          "value": "Common Commands"
        }
