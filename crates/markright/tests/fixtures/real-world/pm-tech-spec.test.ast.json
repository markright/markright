      "level": 2,
      "type": "heading"
    },
    {
      "content": [
        {
          "type": "text",
          "value": "This document specifies the design for a real-time notification system that supports push, email, and in-app delivery channels."
        }
      ],
      "type": "paragraph"
    },
    {
      "max_level": 3,
      "min_level": 2,
      "type": "toc"
    },
    {
      "content": [
        {
          "type": "text",
          "value": "Requirements"
        }
