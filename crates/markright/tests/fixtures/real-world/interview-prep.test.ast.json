      "type": "heading"
    },
    {
      "items": [
        {
          "children": [
            {
              "content": [
                {
                  "type": "text",
                  "value": "Given a long URL, generate a short URL"
                }
              ],
              "type": "paragraph"
            }
          ]
        },
        {
          "children": [
            {
              "content": [
                {
                  "type": "text",
                  "value": "Given a short URL, redirect to the original URL"
                }
              ],
              "type": "paragraph"
            }
          ]
        },
        {
          "children": [
            {
              "content": [
                {
                  "type": "text",
                  "value": "URLs expire after a configurable TTL"
                }
              ],
              "type": "paragraph"
            }
          ]
        }
      ],
      "start": 1,
      "type": "ordered_list"
    },
    {
      "content": [
        {
          "type": "text",
          "value": "Non-Functional"
        }
      ],
      "level": 3,
      "type": "heading"
    },
    {
      "items": [
        {
          "children": [
            {
              "content": [
                {
                  "type": "text",
                  "value": "100 million URLs generated per day"
                }
              ],
              "type": "paragraph"
            }
          ]
        },
        {
          "children": [
            {
              "content": [
                {
                  "type": "text",
                  "value": "10:1 read-to-write ratio"
                }
              ],
              "type": "paragraph"
            }
          ]
        },
        {
          "children": [
            {
              "content": [
                {
                  "type": "text",
                  "value": "99.99% availability"
                }
              ],
              "type": "paragraph"
            }
          ]
        },
        {
          "children": [
            {
              "content": [
                {
                  "type": "text",
                  "value": "Redirect latency under 100ms"
                }
              ],
              "type": "paragraph"
            }
          ]
        }
      ],
      "type": "unordered_list"
    },
    {
      "content": [
        {
          "type": "text",
          "value": "Capacity Estimation"
        }
      ],
      "level": 2,
      "type": "heading"
    },
    {
      "content": [
        {
          "type": "text",
          "value": "Writes per second: "
        },
        {
          "type": "inline_math",
          "value": "100M / 86400 \\approx 1157"
        },
        {
          "type": "text",
          "value": " writes/sec"
        }
      ],
      "type": "paragraph"
    },
    {
      "content": [
        {
          "type": "text",
          "value": "Reads per second: "
        },
        {
          "type": "inline_math",
          "value": "1157 \\times 10 \\approx 11570"
        },
        {
          "type": "text",
          "value": " reads/sec"
        }
      ],
      "type": "paragraph"
    },
    {
      "content": [
        {
          "type": "text",
          "value": "Storage for 5 years: "
        },
        {
          "type": "inline_math",
          "value": "100M \\times 365 \\times 5 \\times 500B \\approx 91.25 TB"
        }
      ],
      "type": "paragraph"
    },
    {
      "content": [
        {
          "type": "text",
          "value": "Key Generation"
        }
      ],
      "level": 2,
      "type": "heading"
    },
    {
      "content": [
        {
          "type": "text",
          "value": "Use "
        },
        {
          "children": [
            {
              "type": "text",
              "value": "base62 encoding"
            }
          ],
          "type": "bold"
        },
        {
          "type": "text",
          "value": " of a 7-character string:"
        }
      ],
      "type": "paragraph"
    },
    {
      "body": "62^7 = 3.5 \\times 10^{12}",
      "type": "math_block"
    },
    {
      "content": [
        {
          "type": "text",
          "value": "This gives us 3.5 trillion unique URLs, sufficient for our scale."
        }
      ],
      "type": "paragraph"
    },
