              "content": [
                {
                  "children": [
                    {
                      "type": "text",
                      "value": "Default"
                    }
                  ],
                  "type": "bold"
                },
                {
                  "type": "text",
                  "value": ": The resting state"
                }
              ],
              "type": "paragraph"
            }
          ]
        },
        {
          "children": [
            {
              "content": [
                {
                  "children": [
                    {
                      "type": "text",
                      "value": "Hover"
                    }
                  ],
                  "type": "bold"
                },
                {
                  "type": "text",
                  "value": ": When the cursor is over the button"
                }
              ],
              "type": "paragraph"
            }
          ]
        },
        {
          "children": [
            {
              "content": [
                {
                  "children": [
                    {
                      "type": "text",
                      "value": "Active"
                    }
                  ],
                  "type": "bold"
                },
                {
                  "type": "text",
                  "value": ": While being pressed"
                }
              ],
              "type": "paragraph"
            }
          ]
        },
        {
          "children": [
            {
              "content": [
                {
                  "children": [
                    {
                      "type": "text",
                      "value": "Focused"
                    }
                  ],
                  "type": "bold"
                },
                {
                  "type": "text",
                  "value": ": When navigated to via keyboard"
                }
              ],
              "type": "paragraph"
            }
          ]
        },
        {
          "children": [
            {
              "content": [
                {
                  "children": [
                    {
                      "type": "text",
                      "value": "Disabled"
                    }
                  ],
                  "type": "bold"
                },
                {
                  "type": "text",
                  "value": ": When the action is unavailable"
                }
              ],
              "type": "paragraph"
            }
          ]
        },
        {
          "children": [
            {
              "content": [
                {
                  "children": [
                    {
                      "type": "text",
                      "value": "Loading"
                    }
                  ],
                  "type": "bold"
                },
                {
                  "type": "text",
                  "value": ": While an async action is in progress"
                }
              ],
              "type": "paragraph"
            }
          ]
        }
      ],
      "type": "unordered_list"
    },
    {
      "content": [
        {
          "type": "text",
          "value": "Usage Guidelines"
        }
      ],
      "level": 2,
      "type": "heading"
    },
    {
      "children": [
        {
          "content": [
            {
              "type": "text",
              "value": "Always use a verb or verb phrase for button labels. \"Save changes\" is better than \"OK\"."
            }
          ],
          "type": "paragraph"
        }
      ],
      "foldable": false,
      "kind": "note",
      "type": "admonition"
    },
    {
      "children": [
        {
          "content": [
            {
              "type": "text",
              "value": "Avoid using more than one primary button per section. Too many calls to action confuse users."
            }
          ],
          "type": "paragraph"
        }
      ],
      "foldable": false,
      "kind": "warning",
      "type": "admonition"
    },
    {
      "children": [
        {
          "content": [
            {
              "type": "text",
              "value": "Destructive buttons must always include a confirmation dialog."
            }
          ],
          "type": "paragraph"
        }
      ],
      "foldable": false,
      "kind": "important",
      "type": "admonition"
    },
    {
      "content": [
        {
          "type": "text",
          "value": "Code Example"
        }
      ],
      "level": 2,
      "type": "heading"
    },
    {
      "body": "import { Button } from \"@/components/ui/button\"\n\nfunction SaveForm() {\n  return (\n    <div>\n      <Button variant=\"primary\" size=\"md\">\n        Save Changes\n      </Button>\n      <Button variant=\"secondary\" size=\"md\">\n        Cancel\n      </Button>\n    </div>\n  )\n}",
      "lang": "tsx",
      "type": "code_block"
    },
    {
      "content": [
        {
          "type": "text",
          "value": "Accessibility"
        }
      ],
      "level": 2,
      "type": "heading"
    },
    {
      "items": [
        {
          "children": [
            {
              "content": [
                {
                  "type": "text",
                  "value": "All buttons must have visible focus indicators"
                }
              ],
              "type": "paragraph"
            }
          ],
          "state": "open"
        },
        {
          "children": [
            {
              "content": [
                {
                  "type": "text",
                  "value": "Icon-only buttons must have an "
                },
                {
                  "type": "inline_code",
                  "value": "aria-label"
                }
              ],
              "type": "paragraph"
            }
          ],
          "state": "open"
        },
        {
          "children": [
            {
              "content": [
                {
                  "type": "text",
                  "value": "Loading buttons must announce state to screen readers"
                }
              ],
              "type": "paragraph"
            }
          ],
          "state": "open"
        },
        {
          "children": [
            {
              "content": [
                {
                  "type": "text",
                  "value": "Color contrast meets WCAG AA requirements"
                }
              ],
              "type": "paragraph"
            }
          ],
          "state": "done"
        },
        {
          "children": [
            {
              "content": [
                {
                  "type": "text",
                  "value": "Touch targets are at least 44x44px"
                }
              ],
              "type": "paragraph"
            }
          ],
          "state": "done"
        }
      ],
      "type": "task_list"
    }
