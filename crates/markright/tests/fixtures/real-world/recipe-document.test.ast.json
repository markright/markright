    },
    {
      "content": [
        {
          "type": "text",
          "value": "Day 1 (Evening)"
        }
      ],
      "level": 3,
      "type": "heading"
    },
    {
      "items": [
        {
          "children": [
            {
              "content": [
                {
                  "type": "text",
                  "value": "Mix levain ingredients in a jar"
                }
              ],
              "type": "paragraph"
            }
          ]
        },
        {
          "children": [
            {
              "content": [
                {
                  "type": "text",
                  "value": "Cover loosely and leave at room temperature"
                }
              ],
              "type": "paragraph"
            }
          ]
        }
      ],
      "start": 1,
      "type": "ordered_list"
    },
    {
      "children": [
        {
          "content": [
            {
              "type": "text",
              "value": "The levain should double in size and have a pleasant tangy smell when ready."
            }
          ],
          "type": "paragraph"
        }
      ],
      "foldable": false,
      "kind": "note",
      "type": "admonition"
    },
    {
      "content": [
        {
          "type": "text",
          "value": "Day 2 (Morning)"
        }
      ],
      "level": 3,
      "type": "heading"
    },
    {
      "items": [
        {
          "children": [
            {
              "content": [
                {
                  "type": "text",
                  "value": "Combine flour and water (reserve 50g water for salt)"
                }
              ],
              "type": "paragraph"
            }
          ]
        },
        {
          "children": [
            {
              "content": [
                {
                  "type": "text",
                  "value": "Rest for 1 hour (autolyse)"
                }
              ],
              "type": "paragraph"
            }
          ]
        },
        {
          "children": [
            {
              "content": [
                {
                  "type": "text",
                  "value": "Add levain and salt with reserved water"
                }
              ],
              "type": "paragraph"
            }
          ]
        },
        {
          "children": [
            {
              "content": [
                {
                  "type": "text",
                  "value": "Mix until fully incorporated"
                }
              ],
              "type": "paragraph"
            }
          ]
        }
      ],
      "start": 1,
      "type": "ordered_list"
    },
    {
      "content": [
        {
          "type": "text",
          "value": "Bulk Fermentation"
        }
      ],
      "level": 3,
      "type": "heading"
    },
    {
      "content": [
        {
          "type": "text",
          "value": "Perform "
        },
        {
          "children": [
            {
              "type": "text",
              "value": "4 sets of stretch and folds"
            }
          ],
          "type": "bold"
        },
        {
          "type": "text",
          "value": " at 30-minute intervals:"
        }
      ],
      "type": "paragraph"
    },
    {
      "items": [
        {
          "children": [
            {
              "content": [
                {
                  "type": "text",
                  "value": "Wet your hands"
                }
              ],
              "type": "paragraph"
            }
          ]
        },
        {
          "children": [
            {
              "content": [
                {
                  "type": "text",
                  "value": "Grab one side of the dough, stretch up, fold over"
                }
              ],
              "type": "paragraph"
            }
          ]
        },
        {
          "children": [
            {
              "content": [
                {
                  "type": "text",
                  "value": "Rotate the bowl 90 degrees"
                }
              ],
              "type": "paragraph"
            }
          ]
        },
        {
          "children": [
            {
              "content": [
                {
                  "type": "text",
                  "value": "Repeat 4 times (once per side)"
                }
              ],
              "type": "paragraph"
            }
          ]
        }
      ],
      "start": 1,
      "type": "ordered_list"
    },
    {
      "children": [
        {
          "content": [
            {
              "type": "text",
              "value": "Do not over-handle the dough. Gentle stretches preserve the gas bubbles."
            }
          ],
          "type": "paragraph"
        }
      ],
      "foldable": false,
      "kind": "warning",
      "type": "admonition"
    },
    {
      "content": [
        {
          "type": "text",
          "value": "Shaping and Proofing"
        }
      ],
      "level": 3,
      "type": "heading"
    },
    {
      "items": [
        {
          "children": [
            {
              "content": [
                {
                  "type": "text",
                  "value": "Turn dough onto lightly floured surface"
                }
              ],
              "type": "paragraph"
            }
          ]
        },
        {
          "children": [
            {
              "content": [
                {
                  "type": "text",
                  "value": "Pre-shape into a round"
                }
              ],
              "type": "paragraph"
            }
          ]
        },
        {
          "children": [
            {
              "content": [
                {
                  "type": "text",
                  "value": "Rest 20 minutes"
                }
              ],
              "type": "paragraph"
            }
          ]
        },
        {
          "children": [
            {
              "content": [
                {
                  "type": "text",
                  "value": "Final shape into a batard or boule"
                }
              ],
              "type": "paragraph"
            }
          ]
        },
        {
          "children": [
            {
              "content": [
                {
                  "type": "text",
                  "value": "Place in a floured banneton"
                }
              ],
              "type": "paragraph"
            }
          ]
        },
        {
          "children": [
            {
              "content": [
                {
                  "type": "text",
                  "value": "Cover and refrigerate overnight"
                }
              ],
              "type": "paragraph"
            }
          ]
        }
      ],
      "start": 1,
      "type": "ordered_list"
    },
    {
      "content": [
        {
          "type": "text",
          "value": "Baking"
        }
      ],
      "level": 3,
      "type": "heading"
    },
    {
      "items": [
        {
          "children": [
            {
              "content": [
                {
                  "type": "text",
                  "value": "Preheat oven to 500F with Dutch oven inside"
                }
              ],
              "type": "paragraph"
            }
          ]
        },
        {
          "children": [
            {
              "content": [
                {
                  "type": "text",
                  "value": "Score the dough with a razor blade"
                }
              ],
              "type": "paragraph"
            }
          ]
        },
        {
          "children": [
            {
              "content": [
                {
                  "type": "text",
                  "value": "Bake covered for 20 minutes"
                }
              ],
              "type": "paragraph"
            }
          ]
        },
        {
          "children": [
            {
              "content": [
                {
                  "type": "text",
                  "value": "Remove lid, reduce to 450F"
                }
              ],
              "type": "paragraph"
            }
          ]
        },
        {
          "children": [
            {
              "content": [
                {
                  "type": "text",
                  "value": "Bake 20-25 more minutes until deep golden brown"
                }
              ],
              "type": "paragraph"
            }
          ]
        }
      ],
      "start": 1,
      "type": "ordered_list"
    },
    {
      "children": [
        {
          "content": [
            {
              "type": "text",
              "value": "For a crispier crust, crack the oven door open during the last 5 minutes of baking."
            }
          ],
          "type": "paragraph"
        }
      ],
      "foldable": false,
      "kind": "tip",
      "type": "admonition"
    }
  ]
}