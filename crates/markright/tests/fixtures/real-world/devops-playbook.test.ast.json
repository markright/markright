      "type": "task_list"
    },
    {
      "content": [
        {
          "type": "text",
          "value": "Pre-Deployment Checks"
        }
      ],
      "level": 2,
      "type": "heading"
    },
    {
      "body": "# Verify cluster connectivity\nkubectl cluster-info\n\n# Check current deployment status\nkubectl get deployments -n production\n\n# Review pending changes\nkubectl diff -f manifests/",
      "lang": "bash",
      "type": "code_block"
    },
    {
      "children": [
        {
          "content": [
            {
              "type": "text",
              "value": "Always run "
            },
            {
              "type": "inline_code",
              "value": "kubectl diff"
            },
            {
              "type": "text",
              "value": " before applying changes to production."
            }
          ],
          "type": "paragraph"
        }
      ],
      "foldable": false,
      "kind": "warning",
      "type": "admonition"
    },
    {
      "content": [
        {
          "type": "text",
          "value": "Deployment Steps"
        }
      ],
      "level": 2,
      "type": "heading"
    },
    {
      "content": [
        {
          "type": "text",
          "value": "1. Update ConfigMaps"
        }
      ],
      "level": 3,
      "type": "heading"
    },
    {
      "body": "kubectl apply -f manifests/configmap.yaml -n production",
      "lang": "bash",
      "type": "code_block"
    },
    {
      "content": [
        {
          "type": "text",
          "value": "2. Deploy New Version"
        }
      ],
      "level": 3,
      "type": "heading"
    },
    {
      "body": "kubectl apply -f manifests/deployment.yaml -n production",
      "lang": "bash",
      "type": "code_block"
    },
    {
      "content": [
        {
          "type": "text",
          "value": "3. Monitor Rollout"
        }
      ],
      "level": 3,
      "type": "heading"
    },
    {
      "body": "kubectl rollout status deployment/api-server -n production --timeout=300s",
      "lang": "bash",
      "type": "code_block"
    },
    {
      "content": [
        {
          "type": "text",
          "value": "Rollback Procedure"
        }
      ],
      "level": 2,
      "type": "heading"
    },
    {
      "children": [
        {
          "content": [
            {
              "type": "text",
              "value": "If the deployment shows errors, roll back immediately."
            }
          ],
          "type": "paragraph"
        }
      ],
      "foldable": false,
      "kind": "important",
      "type": "admonition"
    },
    {
      "body": "# Check rollout history\nkubectl rollout history deployment/api-server -n production\n\n# Rollback to previous version\nkubectl rollout undo deployment/api-server -n production",
      "lang": "bash",
      "type": "code_block"
    },
    {
