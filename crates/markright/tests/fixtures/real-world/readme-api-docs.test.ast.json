      "type": "paragraph"
    },
    {
      "body": "{\n  \"data\": [\n    {\n      \"id\": \"usr_123\",\n      \"name\": \"Alice\",\n      \"email\": \"alice@example.com\"\n    }\n  ],\n  \"meta\": {\n    \"page\": 1,\n    \"per_page\": 20,\n    \"total\": 142\n  }\n}",
      "lang": "json",
      "type": "code_block"
