      "type": "heading"
    },
    {
      "content": [
        {
          "type": "text",
          "value": "All API requests require a Bearer token in the "
        },
        {
          "type": "inline_code",
          "value": "Authorization"
        },
        {
          "type": "text",
          "value": " header."
        }
      ],
      "type": "paragraph"
    },
    {
      "body": "GET /api/v2/users\nAuthorization: Bearer <your-token>\nContent-Type: application/json",
      "lang": "http",
      "type": "code_block"
    },
    {
      "children": [
        {
          "content": [
            {
              "type": "text",
              "value": "Tokens expire after 24 hours. Use the refresh endpoint to obtain a new token."
            }
          ],
          "type": "paragraph"
        }
      ],
      "foldable": false,
      "kind": "warning",
      "type": "admonition"
    },
    {
      "content": [
        {
          "type": "text",
          "value": "Endpoints"
        }
