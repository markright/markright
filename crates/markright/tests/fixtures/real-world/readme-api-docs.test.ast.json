      "level": 2,
      "type": "heading"
    },
    {
      "content": [
        {
          "type": "text",
          "value": "GET /api/v2/users"
        }
      ],
      "level": 3,
      "type": "heading"
    },
    {
      "content": [
        {
          "type": "text",
          "value": "Returns a list of users."
        }
      ],
      "type": "paragraph"
    },
    {
      "content": [
        {
          "children": [
            {
              "type": "text",
              "value": "Query Parameters:"
