      "type": "paragraph"
    },
    {
      "items": [
        {
          "definitions": [
            [
              {
                "type": "text",
                "value": "The page number (default: 1)"
              }
            ]
          ],
          "term": [
            {
              "type": "text",
              "value": "page"
            }
          ]
        },
        {
          "definitions": [
            [
              {
                "type": "text",
                "value": "Number of results per page (default: 20, max: 100)"
              }
            ]
          ],
          "term": [
            {
              "type": "text",
              "value": "per_page"
            }
          ]
        },
        {
          "definitions": [
            [
              {
                "type": "text",
                "value": "Sort field ("
              },
              {
                "type": "inline_code",
                "value": "name"
              },
              {
                "type": "text",
                "value": ", "
              },
              {
                "type": "inline_code",
                "value": "created_at"
              },
              {
                "type": "text",
                "value": ", "
              },
              {
                "type": "inline_code",
                "value": "email"
              },
              {
                "type": "text",
                "value": ")"
              }
            ]
          ],
          "term": [
            {
              "type": "text",
              "value": "sort"
            }
          ]
        }
