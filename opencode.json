{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "moon": {
      "type": "local",
      "command": ["moon", "mcp"],
      "enabled": true
    },
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp/oauth",
      "enabled": true
    },
    "grep_app": {
      "type": "remote",
      "url": "https://mcp.grep.app",
      "enabled": true
    },
    "websearch": {
      "type": "remote",
      "url": "https://mcp.exa.ai/mcp",
      "enabled": true
    },
    "search-mcp": {
      "type": "remote",
      "url": "https://search-mcp.parallel.ai/mcp",
      "enabled": true
    }
  }
}
